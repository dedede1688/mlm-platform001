generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  phone                  String         @unique
  email                  String?        @unique
  passwordHash           String         @map("password_hash")
  nickname               String?
  avatarUrl              String?        @map("avatar_url")
  level                  Int            @default(1) @map("level")
  referrerId             String?        @map("referrer_id")
  parentId               String?        @map("parent_id")
  position               Int?           @map("position")
  balance                Float          @default(0) @map("balance")
  frozenBalance          Float          @default(0) @map("frozen_balance")
  totalPoints            Int            @default(0) @map("total_points")
  unlockedPoints         Int            @default(0) @map("unlocked_points")
  lockedPoints           Int            @default(0) @map("locked_points")
  upgradeProductCount    Int            @default(0) @map("upgrade_product_count")
  directSalesAmount      Float          @default(0) @map("direct_sales_amount")
  directDistributorCount Int            @default(0) @map("direct_distributor_count")
  role                   String         @default("user") @map("role")
  status                 String         @default("active") @map("status")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  cartItems              Cart[]
  dividends              Dividend[]
  manualRewards          ManualReward[]
  operationLogs          OperationLog[]
  orders                 Order[]
  pointsRecords          PointsRecord[]
  rewards                Reward[]
  addresses              Address[]
  balanceRecords         BalanceRecord[]
  parent                 User?          @relation("ParentRelation", fields: [parentId], references: [id])
  children               User[]         @relation("ParentRelation")
  referrer               User?          @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referrals              User[]         @relation("ReferrerRelation")
  withdrawals            Withdrawal[]
  refundRequests         RefundRequest[]
  paymentPasswordHash     String?   @map("payment_password_hash")   // v43-2: 支付密码 hash（bcryptjs）

  @@index([referrerId])
  @@index([parentId])
  @@index([level])
  @@index([status])
  @@map("users")
}

model Product {
  id               String      @id @default(uuid())
  name             String
  description      String?
  imageUrl         String?     @map("image_url")
  retailPrice      Float       @map("retail_price")
  memberPrice      Float       @map("member_price")
  stock            Int         @default(0)
  isUpgradeProduct Boolean     @default(false) @map("is_upgrade_product")
  maxPointsRatio   Int         @default(50) @map("max_points_ratio")
  benefits         Json?       @map("benefits")
  specs            Json?       @map("specs")
  research         String?     @map("research")
  images           Json?       @map("images")
  videoUrl         String?     @map("video_url")
  status           String      @default("active") @map("status")
  sortOrder        Int         @default(0) @map("sort_order")
  categoryId       String?     @map("category_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  cartItems        Cart[]
  orderItems       OrderItem[]
  category         Category?   @relation(fields: [categoryId], references: [id])

  @@index([status])
  @@index([isUpgradeProduct])
  @@index([categoryId])
  @@map("products")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?    @map("parent_id")
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@index([parentId])
  @@map("categories")
}

model Order {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  orderNo        String      @unique @map("order_no")
  totalAmount    Float       @map("total_amount")
  pointsUsed     Int         @default(0) @map("points_used")
  pointsDiscount Float       @default(0) @map("points_discount")
  payAmount      Float       @map("pay_amount")
  status         String      @default("pending") @map("status")
  trackingNumber String?     @map("tracking_number")
  paidAt         DateTime?   @map("paid_at")
  shippedAt      DateTime?   @map("shipped_at")
  completedAt    DateTime?   @map("completed_at")
  cancelledAt    DateTime?   @map("cancelled_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  dividends      Dividend[]
  items          OrderItem[]
  user           User        @relation(fields: [userId], references: [id])
  rewards        Reward[]
  refundRequests RefundRequest[]
  recipientName        String?   @map("recipient_name")       // v43-2: 收货人姓名
  recipientPhone       String?   @map("recipient_phone")      // v43-2: 收货人电话
  shippingAddress      String?   @map("shipping_address")     // v43-2: 收货地址
  paymentVerified      Boolean  @default(false) @map("payment_verified") // v43-2: 支付密码是否验证通过

  @@index([userId])
  @@index([status])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Float    @map("unit_price")
  totalPrice Float    @map("total_price")
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model PointsRecord {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  type           String   @map("type")
  amount         Int
  totalPoints    Int      @map("total_points")
  unlockedPoints Int      @map("unlocked_points")
  lockedPoints   Int      @map("locked_points")
  sourceId       String?  @map("source_id")
  description    String?  @map("description")
  relatedUserId  String?  @map("related_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([sourceId])
  @@map("points_records")
}

model Reward {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   @map("type")
  orderId    String   @map("order_id")
  amount     Float
  fromUserId String?  @map("from_user_id")
  level      Int?     @map("level")
  status     String   @default("pending") @map("status")
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order    @relation(fields: [orderId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([orderId])
  @@index([status])
  @@map("rewards")
}

model Dividend {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  orderId      String   @map("order_id")
  amount       Float
  userLevel    Int      @map("user_level")
  totalPool    Float    @map("total_pool")
  dividendDate DateTime @map("dividend_date")
  createdAt    DateTime @default(now()) @map("created_at")
  order        Order    @relation(fields: [orderId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([dividendDate])
  @@map("dividends")
}

model Withdrawal {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  amount       Float
  status       String    @default("pending") @map("status")
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  rejectReason String?   @map("reject_reason")
  paidAt       DateTime? @map("paid_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

model SystemConfig {
  id             String   @id @default(uuid())
  key            String   @unique
  value          String
  description    String?
  siteName       String?  @default("敏维科技") @map("site_name")
  logoUrl        String?  @default("/logo.png") @map("logo_url")
  contactPhone   String?  @default("18566793066") @map("contact_phone")
  serviceEmail   String?  @default("381901944@qq.com") @map("service_email")
  serviceTime    String?  @default("周一至周日 9:00-21:00") @map("service_time")
  companyName    String?  @default("广州敏维科技有限公司") @map("company_name")
  companyAddress String?  @default("广州市花都区金谷南路") @map("company_address")
  icp            String?  @default("粤ICP备XXXXXXXX号")
  copyright      String?  @default("2026")
  aboutUs        String?  @map("about_us")
  termsHtml      String?  @map("terms_html")
  privacyHtml    String?  @map("privacy_html")
  helpFaq        Json?    @map("help_faq")
  banners        Json?    @map("banners")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  seoKeywords    String?  @map("seo_keywords")
  paymentProvider   String?  @default("mock") @map("payment_provider")
  paymentMerchantId String?  @map("payment_merchant_id")
  paymentSecret     String?  @map("payment_secret")
  paymentNotifyUrl  String?  @map("payment_notify_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model LevelSnapshot {
  id                     String   @id @default(uuid())
  userId                 String   @map("user_id")
  snapshotDate           DateTime @map("snapshot_date")
  level                  Int      @map("level")
  directDistributorCount Int      @map("direct_distributor_count")
  directSalesAmount      Float    @map("direct_sales_amount")
  createdAt              DateTime @default(now()) @map("created_at")

  @@unique([userId, snapshotDate])
  @@index([snapshotDate])
  @@index([level])
  @@map("level_snapshots")
}

model PointsUnlockSchedule {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  orderId         String    @map("order_id")
  totalPoints     Int       @map("total_points")
  unlockedPoints  Int       @default(0) @map("unlocked_points")
  remainingPoints Int       @map("remaining_points")
  dailyUnlockRate Float     @map("daily_unlock_rate")
  totalDays       Int       @map("total_days")
  completedDays   Int       @default(0) @map("completed_days")
  status          String    @default("active") @map("status")
  nextUnlockDate  DateTime? @map("next_unlock_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([nextUnlockDate])
  @@map("points_unlock_schedules")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("carts")
}

model ManualReward {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  amount     Float
  type       String   @default("manual") @map("type")
  reason     String   @map("reason")
  operatorId String?  @map("operator_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("manual_rewards")
}

model OperationLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  module    String
  targetId  String?  @map("target_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("operation_logs")
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  type      String   @map("type")
  channel   String   @map("channel")
  subject   String?  @map("subject")
  content   String   @map("content")
  enabled   Boolean  @default(true) @map("enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([type, channel])
  @@index([type])
  @@index([channel])
  @@index([enabled])
  @@map("notification_templates")
}

model RefundRequest {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  userId       String   @map("user_id")
  amount       Float
  reason       String
  description  String?
  images       Json?    // 存储图片 URL 数组，如 ["url1", "url2"]
  status       String   @default("pending") // pending, approved, rejected, completed
  adminComment String?  @map("admin_comment")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("refund_requests")
}

model Address {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  recipientName String   @map("recipient_name")
  phone         String
  province      String   // 省
  city          String   // 市
  district      String   // 区
  detailAddress String   @map("detail_address")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
  @@map("addresses")
}

model BalanceRecord {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  type          String   @map("type")             // v43-7: payment / refund / reward / withdraw_freeze / withdraw / unfreeze / admin_adjust / manual_reward / refund_reward / refund_dividend
  amount        Float    @map("amount")           // +/- 正数加/负数减
  balance       Float    @map("balance")          // 变动后可用余额
  frozenBalance Float    @map("frozen_balance")   // 变动后冻结余额
  sourceType    String?  @map("source_type")      // v43-7: order / reward / withdrawal / manual_reward / admin / dividend
  sourceId      String?  @map("source_id")
  description   String?  @map("description")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("balance_records")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model banners {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  image_url  String
  link       String?
  title      String?
  alt        String?
  order      Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}
