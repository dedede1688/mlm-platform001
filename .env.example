# ===========================================
# MLM Platform 环境变量配置
# ===========================================

# ---- 数据库配置 ----
# PostgreSQL 连接字符串（必需）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://user:password@localhost:5432/mlm_platform"

# ---- JWT 认证 ----
# JWT 签名密钥（必需，建议至少32位随机字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-jwt-secret-key-at-least-32-characters-long"

# ---- Supabase 配置 ----
# Supabase 项目 URL（必需）
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Supabase 匿名密钥（必需，可在 Supabase 控制台获取）
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Supabase 服务角色密钥（必需，用于服务端操作，切勿泄露）
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ---- 邮件服务配置（可选）----
# SMTP 服务器地址
SMTP_HOST="smtp.example.com"
# SMTP 端口（通常为 587 或 465）
SMTP_PORT="587"
# SMTP 用户名
SMTP_USER="your-email@example.com"
# SMTP 密码
SMTP_PASSWORD="your-email-password"
# 发件人地址
SMTP_FROM="noreply@example.com"

# ---- 短信服务配置（可选）----
# 短信服务商（aliyun | tencent）
SMS_PROVIDER="aliyun"
# 阿里云/腾讯云 AccessKey ID
SMS_ACCESS_KEY_ID="your-access-key-id"
# 阿里云/腾讯云 AccessKey Secret
SMS_ACCESS_KEY_SECRET="your-access-key-secret"
# 短信签名
SMS_SIGN_NAME="your-sign-name"
# 短信模板编号
SMS_TEMPLATE_CODE="your-template-code"

# ---- 应用配置 ----
# 运行环境（development | production | test）
NODE_ENV="development"
# 应用公开访问地址（用于生成链接、回调等）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
